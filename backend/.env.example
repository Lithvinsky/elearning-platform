NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/learnease-pro
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret_2
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
# Local dev: `lax`. Production (Vercel + separate API host): set `none` or rely on NODE_ENV=production default in env.js.
REFRESH_COOKIE_SAMESITE=lax
# Comma-separated browser origins (required for browser login / cookies). Include your Vercel URL in production.
CLIENT_ORIGIN=http://localhost:5173,https://elearning-platform-orpin-zeta.vercel.app
